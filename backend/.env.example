# ─────────────────────────────────────────────────────────────────────────────
# Multi-Tenant AI Customer Care Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key — get one free at https://aistudio.google.com
# Both variables must be set to the same key:
#   GEMINI_API_KEY is used by the direct REST fallback
#   GOOGLE_API_KEY is used by LangChain (langchain-google-genai)
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here

# ─── LLM Model Configuration ─────────────────────────────────────────────────
# Primary model — tried first on every request
# gemini-3.5-flash has a separate quota pool from 2.x models (~1500 RPD free)
LLM_MODEL=gemini-3.5-flash

# Fallback models — tried in order when primary hits 429 quota limit
# Each model has its own independent quota counter
LLM_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3-flash-preview,gemini-2.0-flash,gemini-2.0-flash-lite

# Max tokens per LLM response (lower = faster responses)
MAX_TOKENS=1024

# ─── Database ─────────────────────────────────────────────────────────────────
# Company profiles DB (SQLite for development; auto-created on first run)
COMPANY_DATABASE_URL=sqlite:///./companies.db

# PostgreSQL for production (uncomment and fill in):
# COMPANY_DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chromadb_store

# ─── App Settings ─────────────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=changeme

# Confidence threshold below which escalation is triggered
CONFIDENCE_THRESHOLD=0.70

# Server port
PORT=8000

# Frontend URL (used for CORS in production — restrict allow_origins in main.py)
FRONTEND_URL=http://localhost:3000
